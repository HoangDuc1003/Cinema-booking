# Runtime
PORT=3000
CLIENT_URL=http://localhost:5173

# MongoDB Atlas or another replica set (transactions are required)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>/<database>

# Redis. Keep the real URL only in the deployment environment or local .env.
REDIS_URL=rediss://:<password>@<host>:<port>
REDIS_KEY_PREFIX=nitrocine
REDIS_CONNECT_TIMEOUT_MS=5000

# Cache TTLs (seconds)
CACHE_MOVIES_TTL_SECONDS=300
CACHE_MOVIE_TTL_SECONDS=1800
CACHE_CINEMAS_TTL_SECONDS=600
CACHE_SHOWTIMES_TTL_SECONDS=120
CACHE_SEAT_MAP_TTL_SECONDS=5

# Coordination and idempotency
SEAT_HOLD_TTL_SECONDS=1800
BOOKING_LOCK_TTL_MS=10000
PAYMENT_LOCK_TTL_MS=30000
PAYMENT_IDEMPOTENCY_TTL_SECONDS=604800

# Clerk
CLERK_PUBLISHABLE_KEY=<clerk_publishable_key>
CLERK_SECRET_KEY=<clerk_secret_key>

# TMDB (server-side bearer token)
TMDB_API_KEY=<tmdb_bearer_token>
TMDB_TIMEOUT_MS=3000

# Stripe
STRIPE_PUBLISHABLE_KEY=<stripe_publishable_key>
STRIPE_SECRET_KEY=<stripe_secret_key>
STRIPE_WEBHOOK_SECRET=<stripe_webhook_secret>

# Inngest
INNGEST_EVENT_KEY=<inngest_event_key>
INNGEST_SIGNING_KEY=<inngest_signing_key>

# Integration tests: use disposable infrastructure only
ALLOW_INTEGRATION_TESTS=false
TEST_MONGODB_URI=mongodb://127.0.0.1:27017/nitrocine_test?replicaSet=rs0
